# --- Real API (default for integration) ---
# Backend must run (e.g. backend/docker + Supabase in backend/.env). Restart `npm run dev` after changes.
VITE_USE_MOCK_AUTH=false
#
# Dev: leave VITE_API_BASE_URL unset so /api is proxied to http://127.0.0.1:8000 (avoids CORS).
# VITE_API_BASE_URL=http://localhost:8000
#
# Mock login (no backend): only in `npm run dev`, string must be exactly "true"
# VITE_USE_MOCK_AUTH=true
