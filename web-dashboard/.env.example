# Local dev: leave unset so the app uses Vite's proxy to http://127.0.0.1:8000 (avoids CORS).
# Only set this if you need to call the gateway directly from the browser:
# VITE_API_BASE_URL=http://localhost:8000
#
# Mock login: only active in `npm run dev` when set to the string "true".
# In mock mode any email + password (8+ chars) signs in — no Supabase.
# Shell environment overrides .env; check with: printenv VITE_USE_MOCK_AUTH
# VITE_USE_MOCK_AUTH=true
