# Local dev: leave unset so the app uses Vite's proxy to http://127.0.0.1:8000 (avoids CORS).
# Only set this if you need to call the gateway directly from the browser:
# VITE_API_BASE_URL=http://localhost:8000
# Set to "true" to use mock login (no backend); any non-empty email + password works
# VITE_USE_MOCK_AUTH=true
